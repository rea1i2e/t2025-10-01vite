<% 
  const splideSegmentImages = [
    { file: "demo/dummy1.jpg", alt: "" },
    { file: "demo/dummy2.jpg", alt: "" },
    { file: "demo/dummy3.jpg", alt: "" },
    { file: "demo/dummy4.jpg", alt: "" },
    { file: "demo/dummy5.jpg", alt: "" },
  ];
%>
<div class="p-splide-segment splide" id="js-splide-segment">
  <div class="p-splide-segment__track splide__track">
    <ul class="p-splide-segment__list splide__list">
      <% splideSegmentImages.forEach((item) => { %>
      <li class="p-splide-segment__item splide__slide">
        <img src="<%- imagePath %><%- item.file %>" alt="<%= ty_stripTags(item.alt) %>">
      </li>
      <% }); %>
    </ul>
  </div>
  <div class="p-splide-segment__controls">
    <div class="p-splide-segment__arrows splide__arrows">
      <button class="p-splide-segment__arrow splide__arrow splide__arrow--prev" type="button" aria-label="前へ"></button>
      <button class="p-splide-segment__arrow splide__arrow splide__arrow--next" type="button" aria-label="次へ"></button>
    </div>
  </div>
</div>
