<%
  const embedSrc = typeof mapEmbedSrc === 'string' ? mapEmbedSrc : '';
  const iframeTitle = typeof mapTitle === 'string' ? mapTitle : '';
  const viewerHref = typeof mapViewerHref === 'string' ? mapViewerHref : '';
  const ratio = aspectRatio === '16-9' ? '16-9' : '4-3';
%>
<div class="p-access-map">
  <div class="p-access-map__embed" data-aspect="<%= ratio %>">
    <iframe
      src="<%- embedSrc %>"
      title="<%- iframeTitle %>"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </div>
  <% if (viewerHref) { %>
    <p class="p-access-map__link">
      <a href="<%- viewerHref %>" target="_blank" rel="noopener noreferrer">地図を大きく見る</a>
    </p>
  <% } %>
</div>
