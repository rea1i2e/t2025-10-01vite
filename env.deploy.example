# GitHub Actions 用シークレットのローカル定義
# このファイルを .env.deploy にコピーして値を設定し、scripts/setup-secrets.sh で反映する
# .env.deploy は .gitignore に含まれるためコミットされない

# --- 必須（FTPデプロイ用） ---
FTP_SERVER=sv2020.wpx.ne.jp
FTP_USERNAME=
FTP_PASSWORD=

# --- 任意（Discord 通知） ---
# DISCORD_WEBHOOK=

# --- 任意（サマリー・通知に表示するURL） ---
# TEST_URL=
